# Integration 默认参数（建议在这里统一修改）
# 使用方式：
#   1) 直接编辑本文件
#   2) 或通过 MC_INTEGRATION_ENV_FILE 指向自定义 env 文件

# 运行模式: auto|compose|external
export MC_RABBITMQ_ENV="${MC_RABBITMQ_ENV:-external}"

# RabbitMQ 管理 API 与管理员账号（用于自动 bootstrap 用户/权限/拓扑）
export RABBITMQ_API_URL="${RABBITMQ_API_URL:-http://127.0.0.1:15672/api}"
export RABBITMQ_ADMIN_USER="${RABBITMQ_ADMIN_USER:-guest}"
export RABBITMQ_ADMIN_PASS="${RABBITMQ_ADMIN_PASS:-guest}"

# task-flow 用户与 vhost
export RABBITMQ_VHOST="${RABBITMQ_VHOST:-mc_integration}"
export RABBITMQ_MASTER_USER="${RABBITMQ_MASTER_USER:-mc_master}"
export RABBITMQ_MASTER_PASS="${RABBITMQ_MASTER_PASS:-master_secret}"
export RABBITMQ_WORKER_USER="${RABBITMQ_WORKER_USER:-mc_worker}"
export RABBITMQ_WORKER_PASS="${RABBITMQ_WORKER_PASS:-worker_secret}"

# perf 端口/规模参数
export RABBITMQ_PORT="${RABBITMQ_PORT:-5672}"
export MC_WORKER_COUNT="${MC_WORKER_COUNT:-5}"
export MC_TASK_COUNT="${MC_TASK_COUNT:-120}"
export MC_TARGET_RATE="${MC_TARGET_RATE:-60}"
export MC_IMAGE_BYTES="${MC_IMAGE_BYTES:-20971520}"
export MC_SIMULATE_PROCESS_MS="${MC_SIMULATE_PROCESS_MS:-80}"

# 构建流程
export MC_SKIP_CONFIGURE="${MC_SKIP_CONFIGURE:-0}"
export MC_SKIP_BUILD="${MC_SKIP_BUILD:-0}"
export MC_KEEP_ENV="${MC_KEEP_ENV:-1}"
